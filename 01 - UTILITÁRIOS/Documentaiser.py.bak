try:
	from unidecode import unidecode  # pyright: ignore[reportMissingImports]
except ImportError:
	def unidecode(value: str) -> str:
		normalized = unicodedata.normalize("NFKD", value)
		return normalized.encode("ascii", "ignore").decode("ascii")


