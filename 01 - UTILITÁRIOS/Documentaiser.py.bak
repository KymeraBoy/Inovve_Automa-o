PROCESS_STATE_FILE = "documentaiser_processo_anexos.json"
PROCESS_EXPORT_DIR = "documentaiser_export"
ANNEX_COMPRESSION_THRESHOLD_MB = 5
ANNEX_COMPRESSION_THRESHOLD_BYTES = ANNEX_COMPRESSION_THRESHOLD_MB * 1024 * 1024
